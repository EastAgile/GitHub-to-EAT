# Maintainer / dev-tracking config — NOT read by the github-to-eat CLI.
#
# Credentials for managing THIS tool's own development on the East Agile Tracker
# (e.g. filing and updating the tool's stories on its project). Used by
# maintainer/tracking scripts only; the CLI never reads EAT_DEV_* — keep them out
# of the runtime .env.
#
# Copy to .env.dev (gitignored) and fill in.

# Agent API key for the tool's own tracker project.
EAT_DEV_AGENT_KEY=

# API base for the tracker that hosts the tool's project (defaults to production).
EAT_DEV_API_BASE=https://api.eastagiletracker.com/api/v1

# The tool's project id on that tracker.
EAT_DEV_PROJECT_ID=91
